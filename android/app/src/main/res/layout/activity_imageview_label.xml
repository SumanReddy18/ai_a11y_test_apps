<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:text="@string/rule2_title"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:layout_marginTop="2dp"
        android:text="@string/rule2_desc"/>

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp"
        android:columnCount="2"
        android:rowCount="5"
        android:useDefaultMargins="false">

        <!-- 1: Portrait of a specific person — no contentDescription -->
        <ImageView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="3dp"
            android:scaleType="centerCrop"
            android:src="@drawable/meaningful_img_01"/>

        <!-- 2: Portrait — generic "image" -->
        <ImageView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="3dp"
            android:scaleType="centerCrop"
            android:src="@drawable/meaningful_img_02"
            android:contentDescription="image"/>

        <!-- 3: Portrait — empty contentDescription hides identity -->
        <ImageView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="3dp"
            android:scaleType="centerCrop"
            android:src="@drawable/meaningful_img_03"
            android:contentDescription=""/>

        <!-- 4: Portrait — filename used as label -->
        <ImageView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="3dp"
            android:scaleType="centerCrop"
            android:src="@drawable/meaningful_img_04"
            android:contentDescription="avatar_04.jpg"/>

        <!-- 5: Product (sneakers) — generic "photo" -->
        <ImageView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="3dp"
            android:scaleType="centerCrop"
            android:src="@drawable/meaningful_img_05"
            android:contentDescription="photo"/>

        <!-- 6: Product — importantForAccessibility="no" hides the meaningful image from TalkBack
             (BrowserStack rule clause: "Inaccessible to Assistive Technology") -->
        <ImageView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="3dp"
            android:scaleType="centerCrop"
            android:src="@drawable/meaningful_img_06"
            android:contentDescription="Nike Air sneaker, white"
            android:importantForAccessibility="no"/>

        <!-- 7: Product (watch) — wrong/marketing label -->
        <ImageView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="3dp"
            android:scaleType="centerCrop"
            android:src="@drawable/meaningful_img_07"
            android:contentDescription="Shop now"/>

        <!-- 8: Warning/status — single word "icon" -->
        <ImageView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="3dp"
            android:scaleType="centerCrop"
            android:src="@drawable/meaningful_img_08"
            android:contentDescription="icon"/>

        <!-- 9: Warning/status — "graphic" -->
        <ImageView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="3dp"
            android:scaleType="centerCrop"
            android:src="@drawable/meaningful_img_09"
            android:contentDescription="graphic"/>

        <!-- 10: Fire/alert — generic "picture" -->
        <ImageView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="3dp"
            android:scaleType="centerCrop"
            android:src="@drawable/meaningful_img_10"
            android:contentDescription="picture"/>
    </GridLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="6dp"
        android:textColor="@color/text_secondary"
        android:textSize="11sp"
        android:text="Violations of ImageView Element Accessibility Label: (1) Missing — absent or empty contentDescription. (2) Inadequate — generic (&quot;image&quot;/&quot;photo&quot;/&quot;icon&quot;/&quot;picture&quot;/&quot;graphic&quot;), filename, or mismatched copy. (3) Inaccessible — label hidden via importantForAccessibility=&quot;no&quot;. WCAG 1.1.1."/>
</LinearLayout>
