<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:text="@string/rule1_title"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:layout_marginTop="2dp"
        android:text="@string/rule1_desc"/>

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp"
        android:columnCount="2"
        android:rowCount="5"
        android:useDefaultMargins="false">

        <!-- 1: no contentDescription -->
        <ImageView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="3dp"
            android:scaleType="centerCrop"
            android:src="@drawable/unsplash_text_01"/>

        <!-- 2: generic "image" -->
        <ImageView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="3dp"
            android:scaleType="centerCrop"
            android:src="@drawable/unsplash_text_02"
            android:contentDescription="image"/>

        <!-- 3: description ignores embedded text -->
        <ImageView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="3dp"
            android:scaleType="centerCrop"
            android:src="@drawable/unsplash_text_03"
            android:contentDescription="A diagram"/>

        <!-- 4: empty contentDescription -->
        <ImageView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="3dp"
            android:scaleType="centerCrop"
            android:src="@drawable/unsplash_text_04"
            android:contentDescription=""/>

        <!-- 5: generic "photo" -->
        <ImageView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="3dp"
            android:scaleType="centerCrop"
            android:src="@drawable/unsplash_text_05"
            android:contentDescription="photo"/>

        <!-- 6: filename used as label -->
        <ImageView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="3dp"
            android:scaleType="centerCrop"
            android:src="@drawable/unsplash_text_06"
            android:contentDescription="img_06.jpg"/>

        <!-- 7: marketing label hides text -->
        <ImageView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="3dp"
            android:scaleType="centerCrop"
            android:src="@drawable/unsplash_text_07"
            android:contentDescription="Welcome banner"/>

        <!-- 8: single word "graphic" -->
        <ImageView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="3dp"
            android:scaleType="centerCrop"
            android:src="@drawable/unsplash_text_08"
            android:contentDescription="graphic"/>

        <!-- 9: generic "icon" -->
        <ImageView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="3dp"
            android:scaleType="centerCrop"
            android:src="@drawable/unsplash_text_09"
            android:contentDescription="icon"/>

        <!-- 10: generic "picture" -->
        <ImageView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="3dp"
            android:scaleType="centerCrop"
            android:src="@drawable/unsplash_text_10"
            android:contentDescription="picture"/>

    </GridLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="6dp"
        android:textColor="@color/text_secondary"
        android:textSize="11sp"
        android:text="Each image visibly contains text. Screen readers get nothing, &quot;image&quot;, &quot;photo&quot;, &quot;graphic&quot;, an empty string, a filename, or unrelated copy — Issue Detection Agent should flag every one."/>
</LinearLayout>
