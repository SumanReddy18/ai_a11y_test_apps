<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher"
        android:theme="@style/Theme.Main">

        <!-- All activities are declared here. Each flavor's manifest decides which
             one carries the LAUNCHER intent-filter and removes the rest. -->

        <activity android:name=".MainActivity" android:exported="true" android:label="@string/app_name" />

        <activity android:name=".ImageWithTextActivity" android:exported="true"
            android:label="1. Images with text" android:theme="@style/Theme.Child" />
        <activity android:name=".ImageViewLabelActivity" android:exported="true"
            android:label="2. ImageView label" android:theme="@style/Theme.Child" />
        <activity android:name=".InteractiveLabelActivity" android:exported="true"
            android:label="3. Interactive label" android:theme="@style/Theme.Child" />
        <activity android:name=".ReadingOrderActivity" android:exported="true"
            android:label="4. Reading order" android:theme="@style/Theme.Child" />
        <activity android:name=".VisualOrderActivity" android:exported="true"
            android:label="5. Visual order" android:theme="@style/Theme.Child" />
        <activity android:name=".MissingHeadingActivity" android:exported="true"
            android:label="6. Missing heading" android:theme="@style/Theme.Child" />
        <activity android:name=".IncorrectHeadingActivity" android:exported="true"
            android:label="7. Incorrect heading" android:theme="@style/Theme.Child" />
        <activity android:name=".AllViolationsActivity" android:exported="false"
            android:label="All violations" android:theme="@style/Theme.Child" />
    </application>

</manifest>
