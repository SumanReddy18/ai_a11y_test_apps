<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout style="@style/ScreenRoot">

        <TextView style="@style/ScreenH1" android:text="@string/rule7_title"/>
        <TextView style="@style/ScreenSub" android:text="@string/rule7_desc"/>

        <TextView style="@style/SectionLabel" android:background="@drawable/badge_red"
            android:text="VIOLATION 1: body paragraph as heading"/>

        <!-- Long body copy is marked as a heading — heading nav lands here as if it were a section title. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/card_bg">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Terms of service"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:textSize="18sp"
                android:accessibilityHeading="true"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="8dp"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:accessibilityHeading="true"
                android:text="By continuing you agree that any data captured by this demo app may be used to train internal QA models, that you understand this is a synthetic accessibility test fixture, and that you will not redistribute the bundled APKs outside your organization."/>
        </LinearLayout>

        <TextView style="@style/SectionLabel" android:background="@drawable/badge_red"
            android:text="VIOLATION 2: inline error labelled as heading"
            android:layout_marginTop="18dp"/>

        <!-- Form error message marked as heading — heading nav will jump to a transient state. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/card_bg">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Email"
                android:textColor="@color/text_primary"
                android:textSize="14sp"/>
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="you@example.com"
                android:inputType="textEmailAddress"
                android:autofillHints="emailAddress"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Email is required."
                android:textColor="@color/violation_red"
                android:textSize="12sp"
                android:paddingTop="4dp"
                android:accessibilityHeading="true"/>
        </LinearLayout>

        <TextView style="@style/SectionLabel" android:background="@drawable/badge_red"
            android:text="VIOLATION 3: every list item is a heading"
            android:layout_marginTop="18dp"/>

        <!-- A list where every row is flagged as a heading — heading nav becomes useless. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/card_bg">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Inbox"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:textSize="18sp"
                android:accessibilityHeading="true"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="10dp"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:text="Anya — your invoice is ready"
                android:accessibilityHeading="true"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="6dp"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:text="GitHub — 3 new pull requests on app-apk"
                android:accessibilityHeading="true"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="6dp"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:text="Mum — call me when you land"
                android:accessibilityHeading="true"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="6dp"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:text="Zomato — 30% off this weekend"
                android:accessibilityHeading="true"/>
        </LinearLayout>

        <TextView style="@style/SectionLabel" android:background="@drawable/badge_red"
            android:text="VIOLATION 4: ad / promo flagged as heading"
            android:layout_marginTop="18dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/card_bg">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Articles"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:textSize="18sp"
                android:accessibilityHeading="true"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sponsored — Try Cloud Plus free for 30 days. No credit card needed."
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:paddingTop="10dp"
                android:accessibilityHeading="true"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Why mobile accessibility matters in 2026"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:paddingTop="14dp"
                android:accessibilityHeading="true"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="5 min read · BrowserStack engineering"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:paddingTop="2dp"/>
        </LinearLayout>

        <TextView style="@style/SectionLabel" android:background="@drawable/badge_red"
            android:text="VIOLATION 5: button label as heading"
            android:layout_marginTop="18dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/card_bg">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Confirm booking"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:textSize="18sp"
                android:accessibilityHeading="true"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mumbai → Goa · Sat 9:40 AM · 2 passengers"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:paddingTop="8dp"/>
            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Pay ₹12,450"
                android:backgroundTint="@color/brand_primary"
                android:textColor="#FFFFFF"
                android:accessibilityHeading="true"/>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="14dp"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:text="Body copy, error messages, list rows, ad blurbs, and even a Button are all flagged with android:accessibilityHeading=&quot;true&quot;. TalkBack heading navigation will treat each one as a section title — pure noise."/>
    </LinearLayout>
</ScrollView>
