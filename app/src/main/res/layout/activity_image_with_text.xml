<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout style="@style/ScreenRoot">

        <TextView style="@style/ScreenH1" android:text="@string/rule1_title"/>
        <TextView style="@style/ScreenSub" android:text="@string/rule1_desc"/>

        <TextView style="@style/SectionLabel" android:background="@drawable/badge_red"
            android:text="VIOLATION 1: no contentDescription"/>

        <!-- Real image containing visible text. No alt at all. -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="8dp"
            android:scaleType="fitCenter"
            android:adjustViewBounds="true"
            android:src="@drawable/text_wrap_image"/>

        <TextView style="@style/SectionLabel" android:background="@drawable/badge_red"
            android:text="VIOLATION 2: generic label &quot;image&quot;"
            android:layout_marginTop="18dp"/>

        <!-- Different image (text filled with picture), generic useless contentDescription -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="8dp"
            android:scaleType="fitCenter"
            android:adjustViewBounds="true"
            android:src="@drawable/text_image_fill"
            android:contentDescription="image"/>

        <TextView style="@style/SectionLabel" android:background="@drawable/badge_red"
            android:text="VIOLATION 3: label ignores embedded text"
            android:layout_marginTop="18dp"/>

        <!-- Quote-in-image; contentDescription does NOT capture the actual text -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="8dp"
            android:scaleType="fitCenter"
            android:adjustViewBounds="true"
            android:src="@drawable/text_image_quote"
            android:contentDescription="A diagram"/>

        <TextView style="@style/SectionLabel" android:background="@drawable/badge_red"
            android:text="VIOLATION 4: empty contentDescription"
            android:layout_marginTop="18dp"/>

        <!-- contentDescription explicitly set to empty string — hides info-bearing image from TalkBack -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="8dp"
            android:scaleType="fitCenter"
            android:adjustViewBounds="true"
            android:src="@drawable/text_image_ocr"
            android:contentDescription=""/>

        <TextView style="@style/SectionLabel" android:background="@drawable/badge_red"
            android:text="VIOLATION 5: generic label &quot;photo&quot;"
            android:layout_marginTop="18dp"/>

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="8dp"
            android:scaleType="fitCenter"
            android:adjustViewBounds="true"
            android:src="@drawable/text_image_fill"
            android:contentDescription="photo"/>

        <TextView style="@style/SectionLabel" android:background="@drawable/badge_red"
            android:text="VIOLATION 6: filename used as label"
            android:layout_marginTop="18dp"/>

        <!-- Filename is not a meaningful label and ignores visible text -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="8dp"
            android:scaleType="fitCenter"
            android:adjustViewBounds="true"
            android:src="@drawable/text_image_quote"
            android:contentDescription="text_image_quote.jpg"/>

        <TextView style="@style/SectionLabel" android:background="@drawable/badge_red"
            android:text="VIOLATION 7: marketing label hides the text"
            android:layout_marginTop="18dp"/>

        <!-- Marketing copy as label, completely ignores embedded text -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="8dp"
            android:scaleType="fitCenter"
            android:adjustViewBounds="true"
            android:src="@drawable/text_image_ocr"
            android:contentDescription="Welcome banner"/>

        <TextView style="@style/SectionLabel" android:background="@drawable/badge_red"
            android:text="VIOLATION 8: single word &quot;graphic&quot;"
            android:layout_marginTop="18dp"/>

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="8dp"
            android:scaleType="fitCenter"
            android:adjustViewBounds="true"
            android:src="@drawable/text_wrap_image"
            android:contentDescription="graphic"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="14dp"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:text="Each image visibly contains text (e.g. &quot;CSS text-wrap&quot;, a filled-text design, a quote, &quot;Image to Text&quot;). A screen-reader user gets nothing, &quot;image&quot;, &quot;A diagram&quot;, &quot;photo&quot;, &quot;graphic&quot;, an empty string, a filename, or unrelated marketing copy — none of which expose the actual text in the picture. The Issue Detection Agent should flag every one."/>
    </LinearLayout>
</ScrollView>
