<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout style="@style/ScreenRoot">

        <TextView style="@style/ScreenH1" android:text="@string/rule8_title"/>
        <TextView style="@style/ScreenSub" android:text="@string/rule8_desc"/>

        <TextView style="@style/SectionLabel" android:background="@drawable/badge_red"
            android:text="VIOLATION 1: article footer links"/>

        <!-- Each line is a real link: the vague phrase is wrapped in a
             ClickableSpan in code, so the scanner sees a LINK element whose
             text ("click here", "Read more", "here") conveys no destination. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/card_bg">

            <TextView
                android:id="@+id/linkClickHere"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="To view our refund policy, click here"
                android:textColor="@color/text_primary"
                android:textColorLink="@color/brand_primary"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/linkReadMore"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="New pricing is now live. Read more"
                android:textColor="@color/text_primary"
                android:textColorLink="@color/brand_primary"
                android:textSize="14sp"
                android:paddingTop="14dp"/>

            <TextView
                android:id="@+id/linkHere"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Full release notes are available here"
                android:textColor="@color/text_primary"
                android:textColorLink="@color/brand_primary"
                android:textSize="14sp"
                android:paddingTop="14dp"/>
        </LinearLayout>

        <TextView style="@style/SectionLabel" android:background="@drawable/badge_red"
            android:text="VIOLATION 2: repeated 'Learn more' links"
            android:layout_marginTop="18dp"/>

        <!-- Three cards, each ending in an identical "Learn more" link. To a
             screen-reader user navigating link-by-link they are indistinguishable. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/card_bg">

            <TextView
                android:id="@+id/linkLearnMore1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Automate tests on real devices. Learn more"
                android:textColor="@color/text_primary"
                android:textColorLink="@color/brand_primary"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/linkLearnMore2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Catch accessibility issues early. Learn more"
                android:textColor="@color/text_primary"
                android:textColorLink="@color/brand_primary"
                android:textSize="14sp"
                android:paddingTop="14dp"/>

            <TextView
                android:id="@+id/linkLearnMore3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Scale your CI pipeline. Learn more"
                android:textColor="@color/text_primary"
                android:textColorLink="@color/brand_primary"
                android:textSize="14sp"
                android:paddingTop="14dp"/>
        </LinearLayout>

        <TextView style="@style/SectionLabel" android:background="@drawable/badge_red"
            android:text="VIOLATION 3: raw URL as link text"
            android:layout_marginTop="18dp"/>

        <!-- Violation: the link text is the raw URL. A screen reader reads the
             whole string character-by-character / host-by-host instead of the
             human purpose of the destination. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/card_bg">

            <TextView
                android:id="@+id/linkRawUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Documentation: https://www.browserstack.com/docs/app-accessibility/overview?ref=demo&amp;src=apk"
                android:textColor="@color/text_primary"
                android:textColorLink="@color/brand_primary"
                android:textSize="14sp"/>
        </LinearLayout>

        <TextView style="@style/SectionLabel" android:background="@drawable/badge_red"
            android:text="VIOLATION 4: more ambiguous links"
            android:layout_marginTop="18dp"/>

        <!-- Extra non-descriptive link phrases to ensure several distinct
             link-text-purpose violations are flagged. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/card_bg">

            <TextView
                android:id="@+id/linkTapHere"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="To update your billing details, tap here"
                android:textColor="@color/text_primary"
                android:textColorLink="@color/brand_primary"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/linkThis"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="For onboarding steps, see this"
                android:textColor="@color/text_primary"
                android:textColorLink="@color/brand_primary"
                android:textSize="14sp"
                android:paddingTop="14dp"/>

            <TextView
                android:id="@+id/linkMore"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Integrations are expanding every week. More"
                android:textColor="@color/text_primary"
                android:textColorLink="@color/brand_primary"
                android:textSize="14sp"
                android:paddingTop="14dp"/>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="14dp"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:text="Every coloured phrase above is a real link (a ClickableSpan in the text), but its label (&quot;click here&quot;, &quot;Read more&quot;, &quot;here&quot;, three identical &quot;Learn more&quot;, a raw URL, &quot;tap here&quot;, &quot;this&quot;, &quot;More&quot;) fails to describe its destination out of context. The AI scanner should flag each link whose text does not convey its purpose."/>
    </LinearLayout>
</ScrollView>
