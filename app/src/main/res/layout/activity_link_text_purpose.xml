<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout style="@style/ScreenRoot">

        <TextView style="@style/ScreenH1" android:text="@string/rule8_title"/>
        <TextView style="@style/ScreenSub" android:text="@string/rule8_desc"/>

        <TextView style="@style/SectionLabel" android:background="@drawable/badge_red"
            android:text="VIOLATION 1: article footer links"/>

        <!-- A row of links where the text gives no clue about the destination.
             Out of context, TalkBack's "links" rotor reads only "click here",
             "read more", "here" — none describe where they go. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/card_bg">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="To view our refund policy, click here"
                android:textColor="@color/text_primary"
                android:textSize="14sp"/>
            <!-- Violation: link text is "click here" — no purpose conveyed -->
            <TextView
                android:id="@+id/linkClickHere"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="click here"
                android:textColor="@color/brand_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:paddingTop="4dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="New pricing is now live."
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:paddingTop="14dp"/>
            <!-- Violation: generic "Read more" -->
            <TextView
                android:id="@+id/linkReadMore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Read more"
                android:textColor="@color/brand_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:paddingTop="4dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Full release notes are available."
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:paddingTop="14dp"/>
            <!-- Violation: bare "here" -->
            <TextView
                android:id="@+id/linkHere"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="here"
                android:textColor="@color/brand_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:paddingTop="4dp"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

        <TextView style="@style/SectionLabel" android:background="@drawable/badge_red"
            android:text="VIOLATION 2: repeated 'Learn more' links"
            android:layout_marginTop="18dp"/>

        <!-- Three cards, each ending in an identical "Learn more" link. To a
             screen-reader user navigating link-by-link they are indistinguishable. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/card_bg">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Automate tests on real devices."
                android:textColor="@color/text_primary"
                android:textSize="14sp"/>
            <TextView
                android:id="@+id/linkLearnMore1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Learn more"
                android:textColor="@color/brand_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:paddingTop="4dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Catch accessibility issues early."
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:paddingTop="14dp"/>
            <TextView
                android:id="@+id/linkLearnMore2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Learn more"
                android:textColor="@color/brand_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:paddingTop="4dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Scale your CI pipeline."
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:paddingTop="14dp"/>
            <TextView
                android:id="@+id/linkLearnMore3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Learn more"
                android:textColor="@color/brand_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:paddingTop="4dp"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

        <TextView style="@style/SectionLabel" android:background="@drawable/badge_red"
            android:text="VIOLATION 3: raw URL as link text"
            android:layout_marginTop="18dp"/>

        <!-- Violation: the link text is the raw URL. A screen reader reads the
             whole string character-by-character / host-by-host instead of the
             human purpose of the destination. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/card_bg">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Documentation:"
                android:textColor="@color/text_primary"
                android:textSize="14sp"/>
            <TextView
                android:id="@+id/linkRawUrl"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="https://www.browserstack.com/docs/app-accessibility/overview?ref=demo&amp;src=apk"
                android:textColor="@color/brand_primary"
                android:textSize="14sp"
                android:paddingTop="4dp"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="14dp"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:text="Every link above is tappable but its label (&quot;click here&quot;, &quot;Read more&quot;, &quot;here&quot;, three identical &quot;Learn more&quot;, and a raw URL) fails to describe its destination out of context. The AI scanner should flag each link whose text does not convey its purpose."/>
    </LinearLayout>
</ScrollView>
