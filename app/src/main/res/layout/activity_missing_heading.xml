<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout style="@style/ScreenRoot">

        <TextView style="@style/ScreenH1" android:text="@string/rule6_title"/>
        <TextView style="@style/ScreenSub" android:text="@string/rule6_desc"/>

        <TextView style="@style/SectionLabel" android:background="@drawable/badge_red"
            android:text="VIOLATION 1: settings page sections"/>

        <!-- "Account", "Notifications", "Privacy" read as section titles but are styled as plain
             body text AND lack android:accessibilityHeading="true". Neither sighted users nor
             TalkBack users get any section-break cue. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/card_bg">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Account"
                android:textColor="@color/text_primary"
                android:textSize="14sp"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Manage email, password, and linked devices."
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:paddingTop="2dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Notifications"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:paddingTop="14dp"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Choose what you get pushed and emailed."
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:paddingTop="2dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Privacy"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:paddingTop="14dp"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Control who can see your activity and profile."
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:paddingTop="2dp"/>
        </LinearLayout>

        <TextView style="@style/SectionLabel" android:background="@drawable/badge_red"
            android:text="VIOLATION 2: blog article sections"
            android:layout_marginTop="18dp"/>

        <!-- Article with one title and two subhead-style labels — all rendered as plain text. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/card_bg">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Why mobile accessibility matters"
                android:textColor="@color/text_primary"
                android:textSize="14sp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="More than 1 in 7 users rely on assistive tech on mobile. Apps that ignore them lock out paying customers and risk legal exposure."
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:paddingTop="10dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="The business case"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:paddingTop="16dp"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Inclusive apps consistently see higher retention and stronger app-store reviews."
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:paddingTop="4dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="The legal case"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:paddingTop="16dp"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Inaccessible apps have triggered ADA and EU EAA complaints in every major market."
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:paddingTop="4dp"/>
        </LinearLayout>

        <TextView style="@style/SectionLabel" android:background="@drawable/badge_red"
            android:text="VIOLATION 3: order summary sections"
            android:layout_marginTop="18dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/card_bg">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Items"
                android:textColor="@color/text_primary"
                android:textSize="14sp"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Noise cancelling headphones · ₹4,999"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:paddingTop="2dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Shipping"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:paddingTop="14dp"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="221B Baker Street, Mumbai · arrives Fri"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:paddingTop="2dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Payment"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:paddingTop="14dp"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Visa ending 4242 · UPI fallback enabled"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:paddingTop="2dp"/>
        </LinearLayout>

        <TextView style="@style/SectionLabel" android:background="@drawable/badge_red"
            android:text="VIOLATION 4: dashboard card titles"
            android:layout_marginTop="18dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/card_bg">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Active users today"
                android:textColor="@color/text_primary"
                android:textSize="14sp"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="38,402"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:paddingTop="2dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Crash-free sessions"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:paddingTop="14dp"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="99.78%"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:paddingTop="2dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Revenue this week"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:paddingTop="14dp"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="₹12.4 L"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:paddingTop="2dp"/>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="14dp"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:text="Every section label above (Account, Notifications, Items, Shipping, …) functionally introduces a new section, but it is rendered as plain body text AND has no android:accessibilityHeading=&quot;true&quot;. Neither sighted users nor TalkBack users get any heading cue — the AI scanner should detect the missing heading from the content."/>
    </LinearLayout>
</ScrollView>
