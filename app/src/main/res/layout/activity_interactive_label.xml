<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:text="@string/rule3_title"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:layout_marginTop="2dp"
        android:text="@string/rule3_desc"/>

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp"
        android:columnCount="2"
        android:rowCount="5"
        android:useDefaultMargins="false">

        <!-- 1: ImageButton — no contentDescription (Missing label) -->
        <ImageButton
            android:id="@+id/btnFavorite"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="3dp"
            android:padding="18dp"
            android:src="@drawable/ic_heart"
            android:scaleType="fitCenter"
            android:background="@drawable/card_bg"/>

        <!-- 2: ImageButton — generic "button" (Inadequate) -->
        <ImageButton
            android:id="@+id/btnShare"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="3dp"
            android:padding="18dp"
            android:src="@drawable/ic_share"
            android:scaleType="fitCenter"
            android:background="@drawable/card_bg"
            android:contentDescription="button"/>

        <!-- 3: ImageButton trash labeled "share" (Contextually inaccurate) -->
        <ImageButton
            android:id="@+id/btnDelete"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="3dp"
            android:padding="18dp"
            android:src="@drawable/ic_trash"
            android:scaleType="fitCenter"
            android:background="@drawable/card_bg"
            android:contentDescription="share"/>

        <!-- 4: ImageButton warning — empty contentDescription -->
        <ImageButton
            android:id="@+id/btnAlert"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="3dp"
            android:padding="18dp"
            android:src="@drawable/ic_warning"
            android:scaleType="fitCenter"
            android:background="@drawable/card_bg"
            android:contentDescription=""/>

        <!-- 5: ImageButton chevron — filename/identifier as label -->
        <ImageButton
            android:id="@+id/btnNext"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="3dp"
            android:padding="18dp"
            android:src="@drawable/ic_chevron"
            android:scaleType="fitCenter"
            android:background="@drawable/card_bg"
            android:contentDescription="ic_chevron"/>

        <!-- 6: ImageButton avatar — generic "icon" -->
        <ImageButton
            android:id="@+id/btnProfile"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="3dp"
            android:padding="18dp"
            android:src="@drawable/ic_avatar"
            android:scaleType="fitCenter"
            android:background="@drawable/card_bg"
            android:contentDescription="icon"/>

        <!-- 7: Wide logo-style ImageButton — no contentDescription -->
        <ImageButton
            android:id="@+id/btnLogo"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="3dp"
            android:padding="10dp"
            android:src="@drawable/ic_logo_text"
            android:scaleType="fitCenter"
            android:background="@drawable/card_bg"/>

        <!-- 8: Promo banner ImageButton — generic "banner" -->
        <ImageButton
            android:id="@+id/btnPromo"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="3dp"
            android:padding="10dp"
            android:src="@drawable/ic_promo_banner"
            android:scaleType="fitCenter"
            android:background="@drawable/card_bg"
            android:contentDescription="banner"/>

        <!-- 9: Custom clickable View (blue CTA) — no label at all -->
        <View
            android:id="@+id/ctaPrimary"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="3dp"
            android:background="@color/brand_primary"
            android:clickable="true"
            android:focusable="true"/>

        <!-- 10: Custom clickable View (red CTA) — no label at all -->
        <View
            android:id="@+id/ctaDanger"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1"
            android:layout_rowWeight="1"
            android:layout_margin="3dp"
            android:background="@color/violation_red"
            android:clickable="true"
            android:focusable="true"/>
    </GridLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="6dp"
        android:textColor="@color/text_secondary"
        android:textSize="11sp"
        android:text="Violations: (1) Missing — absent or empty contentDescription. (2) Inadequate — generic (&quot;button&quot;, &quot;icon&quot;, &quot;banner&quot;) or filename. (3) Contextually wrong — label does not match the element&apos;s action. (4) Custom clickable Views with no label at all. WCAG 1.3.1 / 2.4.6 / 4.1.2."/>
</LinearLayout>
