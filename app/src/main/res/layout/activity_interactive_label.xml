<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:text="@string/rule3_title"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="2dp"
            android:text="@string/rule3_desc"/>

        <!-- ===== Interactable elements (ImageButton / custom clickable Views) ===== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:text="Interactable elements — ImageButton / clickable View"/>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:columnCount="2"
            android:useDefaultMargins="false">

            <!-- 1: ImageButton — no contentDescription (Missing label) -->
            <ImageButton
                android:id="@+id/btnFavorite"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_columnWeight="1"
                android:layout_margin="3dp"
                android:padding="18dp"
                android:src="@drawable/ic_heart"
                android:scaleType="fitCenter"
                android:background="@drawable/card_bg"/>

            <!-- 2: ImageButton — generic "button" (Inadequate) -->
            <ImageButton
                android:id="@+id/btnShare"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_columnWeight="1"
                android:layout_margin="3dp"
                android:padding="18dp"
                android:src="@drawable/ic_share"
                android:scaleType="fitCenter"
                android:background="@drawable/card_bg"
                android:contentDescription="button"/>

            <!-- 3: ImageButton trash labeled "share" (Contextually inaccurate) -->
            <ImageButton
                android:id="@+id/btnDelete"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_columnWeight="1"
                android:layout_margin="3dp"
                android:padding="18dp"
                android:src="@drawable/ic_trash"
                android:scaleType="fitCenter"
                android:background="@drawable/card_bg"
                android:contentDescription="share"/>

            <!-- 4: ImageButton warning — empty contentDescription -->
            <ImageButton
                android:id="@+id/btnAlert"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_columnWeight="1"
                android:layout_margin="3dp"
                android:padding="18dp"
                android:src="@drawable/ic_warning"
                android:scaleType="fitCenter"
                android:background="@drawable/card_bg"
                android:contentDescription=""/>

            <!-- 5: ImageButton chevron — filename/identifier as label -->
            <ImageButton
                android:id="@+id/btnNext"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_columnWeight="1"
                android:layout_margin="3dp"
                android:padding="18dp"
                android:src="@drawable/ic_chevron"
                android:scaleType="fitCenter"
                android:background="@drawable/card_bg"
                android:contentDescription="ic_chevron"/>

            <!-- 6: ImageButton avatar — generic "icon" -->
            <ImageButton
                android:id="@+id/btnProfile"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_columnWeight="1"
                android:layout_margin="3dp"
                android:padding="18dp"
                android:src="@drawable/ic_avatar"
                android:scaleType="fitCenter"
                android:background="@drawable/card_bg"
                android:contentDescription="icon"/>

            <!-- 7: Custom clickable View (blue CTA) — no label at all -->
            <View
                android:id="@+id/ctaPrimary"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_columnWeight="1"
                android:layout_margin="3dp"
                android:background="@color/brand_primary"
                android:clickable="true"
                android:focusable="true"/>

            <!-- 8: Custom clickable View (red CTA) — no label at all -->
            <View
                android:id="@+id/ctaDanger"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_columnWeight="1"
                android:layout_margin="3dp"
                android:background="@color/violation_red"
                android:clickable="true"
                android:focusable="true"/>
        </GridLayout>

        <!-- ===== Switch elements (Switch element content label) ===== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:text="Switch elements — Switch element content label"/>

        <!-- Switch — no android:text, no contentDescription (Missing label) -->
        <Switch
            android:id="@+id/switchMissing"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"/>

        <!-- SwitchCompat — generic contentDescription (Inadequate) -->
        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchGeneric"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:contentDescription="switch"/>

        <!-- ===== Checkbox elements (Checkbox element content label) ===== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:text="Checkbox elements — Checkbox element content label"/>

        <!-- CheckBox — no android:text, no contentDescription (Missing label) -->
        <CheckBox
            android:id="@+id/checkboxMissing"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"/>

        <!-- CheckBox — generic contentDescription (Inadequate) -->
        <CheckBox
            android:id="@+id/checkboxGeneric"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:contentDescription="checkbox"/>

        <!-- ===== Editable elements (Editable element content label) ===== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:text="Editable elements — Editable element content label"/>

        <!-- EditText — no hint, no contentDescription, no labelFor (Missing label) -->
        <EditText
            android:id="@+id/editMissing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:inputType="text"
            android:importantForAutofill="no"/>

        <!-- Visible caption that is NOT associated with the field via labelFor, so the
             editable element still has no programmatic label. -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:text="Email"/>

        <EditText
            android:id="@+id/editUnassociated"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textEmailAddress"
            android:importantForAutofill="no"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="12dp"
            android:paddingBottom="8dp"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:text="Violations: every interactive control above lacks a usable accessibility label. Interactable (ImageButton/View): missing, generic (&quot;button&quot;, &quot;icon&quot;), filename, or contextually wrong. Switch &amp; Checkbox: no android:text and no contentDescription (or a generic one). Editable (EditText): no hint, no contentDescription, and a visible caption that is not linked via labelFor. WCAG 1.3.1 / 2.4.6 / 4.1.2."/>
    </LinearLayout>
</ScrollView>
